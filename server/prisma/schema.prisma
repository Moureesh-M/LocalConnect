generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
}

model Issue {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  assignedTo  String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  location    String
  eventDate   DateTime
  rsvpCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

model HelpRequest {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  neededBy      DateTime
  status        String   @default("OPEN")
  volunteerName String?
  createdAt     DateTime @default(now())
}
